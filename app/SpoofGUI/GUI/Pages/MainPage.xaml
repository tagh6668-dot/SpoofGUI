<Page
    x:Class="SpoofGUI.GUI.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required"
    Background="{StaticResource SurfaceBase}">

    <Grid Padding="32,32,32,32">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="14" IsStaggeringEnabled="True" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock x:Name="HeadlineText" Text="idle" Style="{StaticResource TextDisplay}" />
            <TextBlock x:Name="HeadlineSub"
                       Text="Connect and use your X-Ray Client."
                       Style="{StaticResource TextBodyMuted}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Margin="0,32,0,0"
                    Orientation="Vertical"
                    Spacing="6">
            <TextBlock Text="Active profile" Style="{StaticResource TextCaption}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
                    <TextBlock x:Name="ProfileName" Text="default" Style="{StaticResource TextH2}" />
                    <TextBlock x:Name="ProfileFlow"
                               Style="{StaticResource TextMono}"
                               Foreground="{StaticResource TextSecondary}"
                               Text="0.0.0.0:40443  →  104.19.229.21:443" />
                    <TextBlock x:Name="ProfileSni"
                               Style="{StaticResource TextMono}"
                               Foreground="{StaticResource TextTertiary}"
                               Text="SNI: www.hcaptcha.com" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource SecondaryButton}"
                        VerticalAlignment="Top"
                        Click="OnEditProfile">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Edit" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Text="edit" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="0,32,0,0"
                    Orientation="Vertical"
                    Spacing="6">
            <TextBlock Text="Listener" Style="{StaticResource TextCaption}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Uptime" Style="{StaticResource TextCaption}" />
                    <TextBlock x:Name="StatUptime" Style="{StaticResource TextMono}" Text="—" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Connections" Style="{StaticResource TextCaption}" />
                    <TextBlock x:Name="StatConns" Style="{StaticResource TextMono}" Text="—" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Outbound interface" Style="{StaticResource TextCaption}" />
                    <TextBlock x:Name="StatIface" Style="{StaticResource TextMono}" Text="—" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="12"
                    Margin="0,16,0,0">
            <Button x:Name="DisconnectButton"
                    Style="{StaticResource DangerButton}"
                    IsEnabled="False"
                    Click="OnDisconnect">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Stop" Foreground="{StaticResource StatusDanger}" />
                    <TextBlock Text="stop" />
                </StackPanel>
            </Button>
            <Button x:Name="ConnectButton"
                    Style="{StaticResource PrimaryButton}"
                    Click="OnConnect">
                <Grid>
                    <StackPanel x:Name="ConnectContent" Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Play" Foreground="#15181E" />
                        <TextBlock Text="start" />
                    </StackPanel>
                    <ProgressRing x:Name="ConnectSpinner"
                                  Width="18" Height="18"
                                  Foreground="#15181E"
                                  IsActive="False"
                                  Visibility="Collapsed" />
                </Grid>
            </Button>
        </StackPanel>
    </Grid>
</Page>
