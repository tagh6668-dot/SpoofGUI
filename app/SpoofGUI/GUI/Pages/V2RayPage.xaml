<Page
    x:Class="SpoofGUI.GUI.Pages.V2RayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required"
    Background="{StaticResource SurfaceBase}">

    <Page.Resources>
        <CollectionViewSource x:Name="ProfilesSource" IsSourceGrouped="True" />
    </Page.Resources>

    <Grid Padding="32,24,32,24" RowSpacing="14">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="14" IsStaggeringEnabled="True" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="V2Ray" Style="{StaticResource TextCaption}" />
            <TextBlock Text="proxy configs" Style="{StaticResource TextDisplay}" />
            <TextBlock x:Name="CoreStatusText"
                       Text="xray: checking"
                       Style="{StaticResource TextMono}"
                       Foreground="{StaticResource TextSecondary}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock Text="Status" Style="{StaticResource TextCaption}" />
                <TextBlock x:Name="StatStatus" Style="{StaticResource TextMono}" Text="idle" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1">
                <TextBlock Text="Uptime" Style="{StaticResource TextCaption}" />
                <TextBlock x:Name="StatUptime" Style="{StaticResource TextMono}" Text="—" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="2">
                <TextBlock Text="Download" Style="{StaticResource TextCaption}" />
                <TextBlock x:Name="StatDown" Style="{StaticResource TextMono}" Text="0 B/s" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="3">
                <TextBlock Text="Upload" Style="{StaticResource TextCaption}" />
                <TextBlock x:Name="StatUp" Style="{StaticResource TextMono}" Text="0 B/s" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="4">
                <TextBlock Text="Total (down / up)" Style="{StaticResource TextCaption}" />
                <TextBlock x:Name="StatTotal" Style="{StaticResource TextMono}" Text="0 B / 0 B" />
            </StackPanel>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="5"
                    Height="54"
                    Background="{StaticResource SurfaceSunken}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border Width="10" Height="2" Background="{StaticResource AccentBase}" VerticalAlignment="Center" />
                            <TextBlock Text="down" Style="{StaticResource TextCaption}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border Width="10" Height="2" Background="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                            <TextBlock Text="up" Style="{StaticResource TextCaption}" />
                        </StackPanel>
                        <TextBlock x:Name="GraphPeak" Style="{StaticResource TextCaption}" Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid x:Name="GraphHost" Grid.Row="1" Margin="0,4,0,0">
                        <Polyline x:Name="UpLine" Stroke="{StaticResource TextSecondary}" StrokeThickness="1.25" StrokeLineJoin="Round" />
                        <Polyline x:Name="DownLine" Stroke="{StaticResource AccentBase}" StrokeThickness="1.5" StrokeLineJoin="Round" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Spacing="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Import" Style="{StaticResource TextH2}" VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        x:Name="SubscriptionsButton"
                        Style="{StaticResource SecondaryButton}"
                        Click="OnManageSubscriptions">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Sync" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock x:Name="SubscriptionsLabel" Text="subscriptions" />
                    </StackPanel>
                </Button>
            </Grid>
            <TextBox x:Name="ImportText"
                     Style="{StaticResource FieldTextBox}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="52"
                     MaxHeight="104"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     PlaceholderText="one config per line — vless://, trojan://, vmess://, ss://, or raw config" />
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ModeSelector" Grid.Column="0" SelectedIndex="0" MinWidth="180" SelectionChanged="OnModeChanged">
                    <ComboBoxItem Content="Proxy Mode" />
                    <ComboBoxItem Content="Tunnel Mode" />
                    <ComboBoxItem Content="System Proxy" />
                </ComboBox>
                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           Text="Mode applies to every config. Proxy = local HTTP/SOCKS · Tunnel = TUN routes all traffic · System Proxy = Windows proxy."
                           Style="{StaticResource TextCaption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Click="OnImport">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Add" Foreground="#15181E" />
                        <TextBlock Text="import" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Saved configs"
                       Style="{StaticResource TextH2}"
                       VerticalAlignment="Center" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12">
                <Button x:Name="ConnectButton" Style="{StaticResource PrimaryButton}" Click="OnConnect">
                    <Grid>
                        <StackPanel x:Name="ConnectContent" Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Play" Foreground="#15181E" />
                            <TextBlock x:Name="ConnectLabel" Text="connect" />
                        </StackPanel>
                        <ProgressRing x:Name="ConnectSpinner"
                                      Width="18" Height="18"
                                      Foreground="#15181E"
                                      IsActive="False"
                                      Visibility="Collapsed" />
                    </Grid>
                </Button>
                <Button x:Name="StopButton" Style="{StaticResource DangerButton}" Click="OnStop">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Stop" Foreground="{StaticResource StatusDanger}" />
                        <TextBlock Text="stop" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}" Click="OnNew">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Add" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Text="new" />
                    </StackPanel>
                </Button>
                <Button x:Name="PingButton" Style="{StaticResource SecondaryButton}" Click="OnPingAll">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon x:Name="PingIcon" Symbol="Clock" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock x:Name="PingLabel" Text="ping all" />
                    </StackPanel>
                </Button>
                <Button x:Name="FastestButton" Style="{StaticResource SecondaryButton}" Click="OnConnectFastest">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Find" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Text="fastest" />
                    </StackPanel>
                </Button>
                <Button x:Name="CancelPingButton"
                        Style="{StaticResource DangerButton}"
                        Click="OnCancelPing"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ProgressRing x:Name="PingSpinner"
                                      Width="16" Height="16"
                                      Foreground="{StaticResource StatusDanger}"
                                      IsActive="False"
                                      Visibility="Collapsed" />
                        <SymbolIcon Symbol="Cancel" Foreground="{StaticResource StatusDanger}" />
                        <TextBlock x:Name="CancelPingLabel" Text="cancel ping" />
                    </StackPanel>
                </Button>
                <Button x:Name="EditButton" Style="{StaticResource SecondaryButton}" Click="OnEdit">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Edit" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Text="edit" />
                    </StackPanel>
                </Button>
                <Button x:Name="DeleteButton" Style="{StaticResource DangerButton}" Click="OnDelete">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Delete" Foreground="{StaticResource StatusDanger}" />
                        <TextBlock Text="delete" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="4" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     Style="{StaticResource FieldTextBox}"
                     PlaceholderText="search configs"
                     TextChanged="OnSearchChanged" />
            <ComboBox x:Name="SortSelector"
                      Grid.Column="1"
                      SelectedIndex="0"
                      SelectionChanged="OnSortChanged">
                <ComboBoxItem Content="newest" />
                <ComboBoxItem Content="name" />
                <ComboBoxItem Content="protocol" />
                <ComboBoxItem Content="ping" />
            </ComboBox>
        </Grid>

        <ListView x:Name="ProfileList"
                  Grid.Row="5"
                  SelectionMode="Multiple"
                  ItemsSource="{Binding Source={StaticResource ProfilesSource}}"
                  SelectionChanged="OnProfileSelected"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.GroupStyle>
                <GroupStyle HidesIfEmpty="True">
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Padding="0,12,0,4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Key}"
                                               Style="{StaticResource TextCaption}"
                                               Foreground="{StaticResource AccentBase}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Count}"
                                               Style="{StaticResource TextCaption}"
                                               Foreground="{StaticResource TextTertiary}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="10,2" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="CornerRadius" Value="6" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <AddDeleteThemeTransition />
                    <ReorderThemeTransition />
                    <ContentThemeTransition />
                </TransitionCollection>
            </ListView.ItemContainerTransitions>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,4" ColumnSpacing="16">
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Select" Click="OnSelectConfig">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Accept" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Ping" Click="OnPingOne">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Clock" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Set group" Click="OnSetGroup">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Folder" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Export config" Click="OnExportConfig">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Copy" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1">
                            <TextBlock Text="{Binding Name}" Style="{StaticResource TextBody}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Address}" Style="{StaticResource TextMono}" FontSize="12" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding LatencySummary}" Style="{StaticResource TextMono}" FontSize="10" Foreground="{StaticResource TextTertiary}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="1">
                            <TextBlock Text="{Binding Protocol}" Style="{StaticResource TextCaption}" HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding Ping}" Style="{StaticResource TextMono}" FontSize="12" Foreground="{StaticResource AccentBase}" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
