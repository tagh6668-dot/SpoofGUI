<Page
    x:Class="SpoofGUI.GUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required"
    Background="{StaticResource SurfaceBase}">

    <Page.Resources>
        <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#F4B656" />
        <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#F6C172" />
        <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#E0A641" />
        <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="#F4B656" />
        <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#15181E" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBase}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="32,48,32,18">
            <StackPanel Spacing="6">
                <TextBlock Text="Settings" Style="{StaticResource TextCaption}" />
                <TextBlock Text="app preferences" Style="{StaticResource TextDisplay}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="32,24,32,40" Spacing="20">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="16" IsStaggeringEnabled="True" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Appearance" Style="{StaticResource TextH2}" />
                        <TextBlock Text="The accent palette is tuned for dark surfaces; light is for bright rooms only."
                                   Style="{StaticResource TextBodyMuted}" />
                    </StackPanel>
                    <RadioButtons x:Name="ThemeChoice"
                                  SelectionChanged="OnThemeChanged"
                                  MaxColumns="2">
                        <x:String>dark</x:String>
                        <x:String>light</x:String>
                    </RadioButtons>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Proxy core" Style="{StaticResource TextH2}" />
                        <TextBlock Text="How the bundled xray core behaves. Takes effect on next connect."
                                   Style="{StaticResource TextBodyMuted}" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Allow insecure TLS" Style="{StaticResource TextBody}" />
                            <TextBlock Text="Skip certificate verification on TLS outbounds. Leave off unless a server uses a self-signed cert."
                                       Style="{StaticResource TextCaption}"
                                       TextWrapping="Wrap"
                                       MaxWidth="560" />
                        </StackPanel>
                        <ToggleSwitch x:Name="AllowInsecureToggle"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      OnContent=""
                                      OffContent=""
                                      MinWidth="0"
                                      Toggled="OnAllowInsecureToggled" />
                    </Grid>

                    <Border Style="{StaticResource SectionDivider}" Margin="0" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Log level" Style="{StaticResource TextBody}" />
                            <TextBlock Text="Verbosity of xray output shown on the Logs page."
                                       Style="{StaticResource TextCaption}" />
                        </StackPanel>
                        <ComboBox x:Name="LogLevelCombo"
                                  Grid.Column="1"
                                  MinWidth="160"
                                  VerticalAlignment="Center"
                                  SelectionChanged="OnLogLevelChanged">
                            <ComboBoxItem Content="none" />
                            <ComboBoxItem Content="error" />
                            <ComboBoxItem Content="warning" />
                            <ComboBoxItem Content="info" />
                            <ComboBoxItem Content="debug" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Connection" Style="{StaticResource TextH2}" />
                        <TextBlock Text="Applies to every V2Ray config."
                                   Style="{StaticResource TextBodyMuted}" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="V2Ray mode" Style="{StaticResource TextBody}" />
                            <TextBlock Text="Proxy, Tunnel, or System Proxy — used by whichever config you connect."
                                       Style="{StaticResource TextCaption}" />
                        </StackPanel>
                        <ComboBox x:Name="DefaultModeCombo"
                                  Grid.Column="1"
                                  MinWidth="180"
                                  VerticalAlignment="Center"
                                  SelectionChanged="OnDefaultModeChanged">
                            <ComboBoxItem Content="Proxy Mode" />
                            <ComboBoxItem Content="Tunnel Mode" />
                            <ComboBoxItem Content="System Proxy" />
                        </ComboBox>
                    </Grid>

                    <Border Style="{StaticResource SectionDivider}" Margin="0" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Fast mode" Style="{StaticResource TextBody}" />
                            <TextBlock Text="Low-latency sockets for the SNI engine (gaming / real-time). Trades some throughput for lower delay. Applies on next connect."
                                       Style="{StaticResource TextCaption}"
                                       TextWrapping="Wrap"
                                       MaxWidth="560" />
                        </StackPanel>
                        <ToggleSwitch x:Name="FastModeToggle"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      OnContent=""
                                      OffContent=""
                                      MinWidth="0"
                                      Toggled="OnFastModeToggled" />
                    </Grid>

                    <Border Style="{StaticResource SectionDivider}" Margin="0" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Kill switch" Style="{StaticResource TextBody}" />
                            <TextBlock Text="If a connected core (SNI engine, xray, or sing-box) drops unexpectedly, block all outbound traffic until you disconnect — prevents leaks. Cleared automatically on disconnect or app exit."
                                       Style="{StaticResource TextCaption}"
                                       TextWrapping="Wrap"
                                       MaxWidth="560" />
                        </StackPanel>
                        <ToggleSwitch x:Name="KillSwitchToggle"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      OnContent=""
                                      OffContent=""
                                      MinWidth="0"
                                      Toggled="OnKillSwitchToggled" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Proxy ports" Style="{StaticResource TextH2}" />
                        <TextBlock Text="Local ports xray exposes for SOCKS5 and HTTP. Change only if another app already uses these. Takes effect on next connect."
                                   Style="{StaticResource TextBodyMuted}"
                                   MaxWidth="560" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="SOCKS5 port" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="SocksPortBox" Style="{StaticResource FieldTextBox}" Width="140" InputScope="Number" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="HTTP port" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="HttpPortBox" Style="{StaticResource FieldTextBox}" Width="140" InputScope="Number" />
                        </StackPanel>
                        <Button x:Name="SavePortsButton"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Bottom"
                                Click="OnSavePorts">
                            <TextBlock Text="save ports" />
                        </Button>
                        <Button x:Name="ResetPortsButton"
                                Style="{StaticResource SecondaryButton}"
                                VerticalAlignment="Bottom"
                                Click="OnResetPorts">
                            <TextBlock Text="reset" />
                        </Button>
                    </StackPanel>
                    <TextBlock x:Name="PortsStatus" Style="{StaticResource TextCaption}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="3">
                        <TextBlock Text="DNS" Style="{StaticResource TextH2}" />
                        <TextBlock Text="DNS servers used in Tunnel mode. Plain IP (1.1.1.1) or a URL (https://1.1.1.1/dns-query). Applies on next connect."
                                   Style="{StaticResource TextBodyMuted}"
                                   MaxWidth="560" />
                    </StackPanel>

                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Remote DNS (proxied)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="RemoteDnsBox" Style="{StaticResource FieldTextBox}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Direct DNS (default)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="DirectDnsBox" Style="{StaticResource FieldTextBox}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Bootstrap DNS" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="BootstrapDnsBox" Style="{StaticResource FieldTextBox}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                            <TextBlock Text="DNS strategy" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="DnsStrategyCombo"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="OnDnsStrategyChanged">
                                <ComboBoxItem Content="prefer_ipv4" />
                                <ComboBoxItem Content="prefer_ipv6" />
                                <ComboBoxItem Content="ipv4_only" />
                                <ComboBoxItem Content="ipv6_only" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="SaveDnsButton"
                                Style="{StaticResource PrimaryButton}"
                                Click="OnSaveDns">
                            <TextBlock Text="save DNS" />
                        </Button>
                        <Button x:Name="ResetDnsButton"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnResetDns">
                            <TextBlock Text="reset" />
                        </Button>
                    </StackPanel>
                    <TextBlock x:Name="DnsStatus" Style="{StaticResource TextCaption}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Updates" Style="{StaticResource TextH2}" />
                        <TextBlock Text="SpoofGUI checks the GitHub releases channel."
                                   Style="{StaticResource TextBodyMuted}" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="UpdateVersion" Text="installed: 0.1.0" Style="{StaticResource TextMono}" />
                            <TextBlock x:Name="UpdateLastCheck" Text="never checked" Style="{StaticResource TextCaption}" />
                            <HyperlinkButton x:Name="UpdateReleaseLink"
                                             Content="open release"
                                             NavigateUri="https://github.com/ZethRise/SpoofGUI/releases"
                                             Visibility="Collapsed"
                                             Padding="0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                            <Button x:Name="InstallUpdateButton"
                                    Style="{StaticResource PrimaryButton}"
                                    Visibility="Collapsed"
                                    Click="OnInstallUpdate">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Download" Foreground="#15181E" />
                                    <TextBlock x:Name="InstallUpdateLabel" Text="download &amp; install" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="CheckUpdatesButton"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="OnCheckUpdates">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Sync" Foreground="{StaticResource TextPrimary}" />
                                    <TextBlock Text="check now" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Border Style="{StaticResource SectionDivider}" Margin="0" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Check on launch" Style="{StaticResource TextBody}" />
                            <TextBlock Text="Quietly check for a newer release each time the app starts (result lands in Logs)."
                                       Style="{StaticResource TextCaption}"
                                       TextWrapping="Wrap"
                                       MaxWidth="560" />
                        </StackPanel>
                        <ToggleSwitch x:Name="CheckOnLaunchToggle"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      OnContent=""
                                      OffContent=""
                                      MinWidth="0"
                                      Toggled="OnCheckOnLaunchToggled" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Backup" Style="{StaticResource TextH2}" />
                        <TextBlock Text="Export all SNI profiles and V2Ray configs to a JSON file, or import them on another machine. Imported profiles are added (existing ones are kept)."
                                   Style="{StaticResource TextBodyMuted}"
                                   MaxWidth="560" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="ExportProfilesButton"
                                Style="{StaticResource PrimaryButton}"
                                Click="OnExportProfiles">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Save" Foreground="#15181E" />
                                <TextBlock Text="export" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ImportProfilesButton"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnImportProfiles">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="OpenFile" Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Text="import" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock x:Name="BackupStatus" Style="{StaticResource TextCaption}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Data &amp; about" Style="{StaticResource TextH2}" />
                        <TextBlock Text="Profiles, configs, and settings live in a local SQLite database."
                                   Style="{StaticResource TextBodyMuted}" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="App data folder" Style="{StaticResource TextBody}" />
                            <TextBlock x:Name="DataFolderText"
                                       Style="{StaticResource TextMono}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button x:Name="OpenDataFolderButton"
                                Grid.Column="1"
                                Style="{StaticResource SecondaryButton}"
                                VerticalAlignment="Center"
                                Click="OnOpenDataFolder">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Folder" Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Text="open folder" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <Border Style="{StaticResource SectionDivider}" Margin="0" />
                    <StackPanel Spacing="2">
                        <TextBlock Text="ZethRise/SpoofGUI" Style="{StaticResource TextBody}" />
                        <HyperlinkButton Content="https://github.com/ZethRise/SpoofGUI"
                                         NavigateUri="https://github.com/ZethRise/SpoofGUI"
                                         Padding="0" />
                        <TextBlock Text="GUI fork for SNI-Spoofing on Windows."
                                   Style="{StaticResource TextBodyMuted}" />
                    </StackPanel>
                </StackPanel>
            </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
