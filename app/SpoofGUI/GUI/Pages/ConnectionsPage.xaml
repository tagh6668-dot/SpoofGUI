<Page
    x:Class="SpoofGUI.GUI.Pages.ConnectionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required"
    Background="{StaticResource SurfaceBase}">

    <Grid Padding="32,48,32,32" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Connections" Style="{StaticResource TextCaption}" />
            <TextBlock Text="live sessions" Style="{StaticResource TextDisplay}" />
            <TextBlock Text="Active TCP sessions on the SNI listener and the local proxy ports, refreshed every second."
                       Style="{StaticResource TextBodyMuted}"
                       MaxWidth="640" />
        </StackPanel>

        <TextBlock x:Name="ConnSummary"
                   Grid.Row="1"
                   Style="{StaticResource TextMono}"
                   FontSize="12"
                   Foreground="{StaticResource TextSecondary}"
                   Text="—" />

        <ListView x:Name="ConnList"
                  Grid.Row="2"
                  SelectionMode="None"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="8"
                            Padding="14,11"
                            Background="{StaticResource SurfaceRaised}"
                            BorderBrush="{StaticResource BorderSubtle}"
                            BorderThickness="1">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{Binding Remote}" Style="{StaticResource TextBody}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Local}" Style="{StaticResource TextMono}" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource SurfaceSunken}"
                                    CornerRadius="{StaticResource RadiusSm}"
                                    Padding="9,3">
                                <TextBlock Text="{Binding State}"
                                           FontFamily="{StaticResource FontFamilyMono}"
                                           FontSize="11"
                                           Foreground="{StaticResource AccentBase}" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
