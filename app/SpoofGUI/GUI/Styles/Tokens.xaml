<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="SurfaceBase"    Color="#1B1E25" />
    <SolidColorBrush x:Key="SurfaceRaised"  Color="#22262F" />
    <SolidColorBrush x:Key="SurfaceSunken"  Color="#15181E" />
    <SolidColorBrush x:Key="BorderSubtle"   Color="#2E333D" />
    <SolidColorBrush x:Key="BorderStrong"   Color="#4A505C" />
    <SolidColorBrush x:Key="TextPrimary"    Color="#F2F3F5" />
    <SolidColorBrush x:Key="TextSecondary"  Color="#A8ADB7" />
    <SolidColorBrush x:Key="TextTertiary"   Color="#6E737E" />
    <SolidColorBrush x:Key="AccentBase"     Color="#F4B656" />
    <SolidColorBrush x:Key="AccentDim"      Color="#7A5A2C" />
    <SolidColorBrush x:Key="StatusDanger"   Color="#D44B3A" />
    <SolidColorBrush x:Key="StatusWarn"     Color="#D8A23B" />

    <x:Double x:Key="Space1">4</x:Double>
    <x:Double x:Key="Space2">8</x:Double>
    <x:Double x:Key="Space3">12</x:Double>
    <x:Double x:Key="Space4">16</x:Double>
    <x:Double x:Key="Space5">20</x:Double>
    <x:Double x:Key="Space6">24</x:Double>
    <x:Double x:Key="Space8">32</x:Double>
    <x:Double x:Key="Space10">48</x:Double>

    <CornerRadius x:Key="RadiusSm">3</CornerRadius>
    <CornerRadius x:Key="RadiusMd">6</CornerRadius>
</ResourceDictionary>
