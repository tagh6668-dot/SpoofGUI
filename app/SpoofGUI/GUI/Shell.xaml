<UserControl
    x:Class="SpoofGUI.GUI.Shell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="using:SpoofGUI.GUI.Pages"
    xmlns:ix="using:SpoofGUI.GUI.Interactions"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    Background="{StaticResource SurfaceBase}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SurfaceSunken}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Vertical"
                            Padding="20,28,20,24"
                            Spacing="2">
                    <Image Source="ms-appx:///Assets/SpoofGUILogo.png"
                           Width="150"
                           HorizontalAlignment="Left"
                           Stretch="Uniform" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Orientation="Vertical"
                            Padding="8,0,8,0"
                            Spacing="2">
                    <Button x:Name="NavMain"
                            Click="OnNavMain"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch"
                            Padding="12,0"
                            MinHeight="40"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="3"
                            ix:PressScale.IsEnabled="True">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Home" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="Main" Style="{StaticResource TextBody}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavConfig"
                            Click="OnNavConfig"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch"
                            Padding="12,0"
                            MinHeight="40"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="3"
                            ix:PressScale.IsEnabled="True">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Edit" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="Configs" Style="{StaticResource TextBody}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavV2Ray"
                            Click="OnNavV2Ray"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch"
                            Padding="12,0"
                            MinHeight="40"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="3"
                            ix:PressScale.IsEnabled="True">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Globe" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="V2Ray" Style="{StaticResource TextBody}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavScanner"
                            Click="OnNavScanner"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch"
                            Padding="12,0"
                            MinHeight="40"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="3"
                            ix:PressScale.IsEnabled="True">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Find" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="SNI Scanner" Style="{StaticResource TextBody}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavConnections"
                            Click="OnNavConnections"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch"
                            Padding="12,0"
                            MinHeight="40"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="3"
                            ix:PressScale.IsEnabled="True">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Link" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="Connections" Style="{StaticResource TextBody}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSettings"
                            Click="OnNavSettings"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch"
                            Padding="12,0"
                            MinHeight="40"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="3"
                            ix:PressScale.IsEnabled="True">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Setting" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="Settings" Style="{StaticResource TextBody}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavLogs"
                            Click="OnNavLogs"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch"
                            Padding="12,0"
                            MinHeight="40"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="3"
                            ix:PressScale.IsEnabled="True">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Document" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="Logs" Style="{StaticResource TextBody}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Orientation="Vertical"
                            Padding="20,16,20,20"
                            Spacing="2">
                    <HyperlinkButton NavigateUri="https://github.com/ZethRise/SpoofGUI"
                                     Padding="0"
                                     Foreground="{StaticResource TextTertiary}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon VerticalAlignment="Center"
                                      Foreground="{StaticResource TextTertiary}"
                                      Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                            <TextBlock Text="SpoofGUI Repo"
                                       Style="{StaticResource TextBody}"
                                       Foreground="{StaticResource TextTertiary}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </HyperlinkButton>
                </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="ContentFrame" Grid.Column="1">
            <Frame.ContentTransitions>
                <TransitionCollection>
                    <NavigationThemeTransition>
                        <NavigationThemeTransition.DefaultNavigationTransitionInfo>
                            <EntranceNavigationTransitionInfo />
                        </NavigationThemeTransition.DefaultNavigationTransitionInfo>
                    </NavigationThemeTransition>
                </TransitionCollection>
            </Frame.ContentTransitions>
        </Frame>
    </Grid>
</UserControl>
